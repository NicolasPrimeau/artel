{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/artel-session-start.sh",
            "timeout": 12,
            "statusMessage": "Loading Artel session context…"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/artel-check-inbox.sh",
            "timeout": 5,
            "statusMessage": "Checking Artel inbox…"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/artel-recall.sh",
            "timeout": 5,
            "statusMessage": "Recalling relevant Artel memory…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/artel-pretool-gotcha.sh",
            "timeout": 5,
            "statusMessage": "Checking Artel notes for this file…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/artel-stop.sh",
            "timeout": 5,
            "statusMessage": "Checking Artel inbox before stopping…"
          }
        ]
      }
    ]
  }
}
